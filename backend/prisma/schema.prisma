generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id          String   @id @default(cuid())
  assetId     String
  assetType   String   // certificate | ssh-key | api-key
  algorithm   String   // RSA2048 | RSA1024 | ECDSA-P256 | Ed25519 | SHA1 | 3DES
  severity    String   // info | warning | critical
  sourceIp    String
  observedAt  DateTime
  eventType   String   // observed | rotation | expiration-warning | error

  // The only schema-level index: backs the date-range filter, ORDER BY observedAt
  // DESC, and day grouping. Common algorithms are dense enough to ride this index
  // directly; selective algorithm filters only ever target the *deprecated*
  // algorithms, covered by a partial index added via raw SQL in the migration
  // (Prisma can't express partial indexes).
  @@index([observedAt])
  @@map("events")
}

